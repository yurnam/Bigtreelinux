# BusyBox config fragment – force MMU semantics for ESP32-S3 Linux target
#
# Two-part fix for the ash NOMMU compile error
# =============================================
#
# Part 1: CONFIG_EXTRA_CFLAGS (PRIMARY FIX)
# ------------------------------------------
# The xtensa-esp32s3-linux-uclibcfdpic toolchain's uClibc-ng headers do NOT
# define __ARCH_USE_MMU__.  BusyBox's include/platform.h checks:
#
#   #if ENABLE_NOMMU || \
#       (defined __UCLIBC__ && \
#        UCLIBC_VERSION > KERNEL_VERSION(0, 9, 28) && \
#        !defined __ARCH_USE_MMU__)
#   # define BB_MMU 0
#
# Because !defined __ARCH_USE_MMU__ is TRUE, BB_MMU=0 even when CONFIG_NOMMU
# is not set.  ash.c line 308 then fires:
#   #if !BB_MMU
#   # error "Do not even bother, ash will not run on NOMMU machine"
#
# Fix: add -D__ARCH_USE_MMU__ to BusyBox's CFLAGS via CONFIG_EXTRA_CFLAGS.
# BusyBox's Makefile.flags uses this to append to CFLAGS:
#   ifneq ($(CONFIG_EXTRA_CFLAGS),)
#   CFLAGS += $(strip $(subst ",,$(CONFIG_EXTRA_CFLAGS)))
# Defining __ARCH_USE_MMU__ forces the !defined check to FALSE → BB_MMU=1.
#
# Part 2: CONFIG_NOMMU must also be unset (secondary fix)
# --------------------------------------------------------
# Even with __ARCH_USE_MMU__ defined, if ENABLE_NOMMU=1 (from CONFIG_NOMMU=y),
# the first term in the OR forces BB_MMU=0.
# CONFIG_NOMMU is kept unset by the BUSYBOX_SET_MMU override in external.mk.
#
CONFIG_EXTRA_CFLAGS="-D__ARCH_USE_MMU__"
# CONFIG_NOMMU is not set
