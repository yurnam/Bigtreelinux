# BusyBox config fragment – force MMU semantics for ESP32-S3 Linux target
#
# Belt-and-suspenders via CONFIG_EXTRA_CFLAGS
# ===========================================
# The primary fix is in br2-external/external.mk: a BUSYBOX_POST_PATCH_HOOKS
# function that sed-patches include/platform.h to add "!defined __xtensa__"
# to the uClibc BB_MMU=0 condition.  Because GCC defines __xtensa__ for all
# Xtensa targets, the condition evaluates to FALSE and BB_MMU stays 1.
#
# This config fragment provides a secondary belt-and-suspenders path via
# CONFIG_EXTRA_CFLAGS: if platform.h is ever updated to remove the uClibc
# condition, -D__ARCH_USE_MMU__ will still force BB_MMU=1.
#
# BusyBox's Makefile.flags appends CONFIG_EXTRA_CFLAGS to KBUILD_CFLAGS:
#   ifneq ($(CONFIG_EXTRA_CFLAGS),)
#   KBUILD_CFLAGS += $(strip $(subst ",,$(CONFIG_EXTRA_CFLAGS)))
#   endif
#
CONFIG_EXTRA_CFLAGS="-D__ARCH_USE_MMU__"
# CONFIG_NOMMU is not set
