# BusyBox config fragment – force MMU=y for ESP32-S3 Linux target
#
# The ESP32-S3 Xtensa LX7 core has a hardware MMU and runs full Linux
# (not uClinux/NOMMU).  In the jcmvbkbc xtensa-fdpic Buildroot fork the
# BR2_XTENSA_USE_MMU → BR2_USE_MMU → CONFIG_MMU propagation path does
# not always reach BusyBox's own Kconfig, leaving CONFIG_MMU unset.
# Without it, BusyBox refuses to compile ash:
#   shell/ash.c: #error "Do not even bother, ash will not run on NOMMU machine"
#
# This fragment is referenced by all three PandaTouch defconfigs via
# BR2_PACKAGE_BUSYBOX_CONFIG_FRAGMENT_FILES and guarantees ash compiles.
CONFIG_MMU=y
