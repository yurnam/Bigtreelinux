# Kernel config fragment – BigTreeTech PandaTouch additions
#
# Applied on top of the base esp32s3_defconfig via
# BR2_LINUX_KERNEL_CONFIG_FRAGMENT_FILES.
#
# Enables:
#   - Framebuffer subsystem + simple-framebuffer driver
#   - Virtual framebuffer console (fbcon)
#   - Goodix GT911 capacitive touch driver
#   - USB host (OHCI/EHC1) + USB mass-storage for thumb-drive rootfs
#   - Filesystem support needed for USB storage

# ── Framebuffer ───────────────────────────────────────────────────────────
CONFIG_FB=y
CONFIG_FB_SIMPLE=y
# Framebuffer console (text output on /dev/fb0)
CONFIG_FRAMEBUFFER_CONSOLE=y
CONFIG_FRAMEBUFFER_CONSOLE_DETECT_PRIMARY=y
CONFIG_FONTS=y
CONFIG_FONT_8x16=y
# Virtual terminal with 256 colours via framebuffer
CONFIG_VT=y
CONFIG_VT_CONSOLE=y

# ── Input / touchscreen ───────────────────────────────────────────────────
CONFIG_INPUT=y
CONFIG_INPUT_EVDEV=y
CONFIG_INPUT_TOUCHSCREEN=y
CONFIG_TOUCHSCREEN_GOODIX=y

# ── USB host + mass storage ───────────────────────────────────────────────
# Enables plugging a USB thumb drive into the USB-A OTG port for a
# larger root filesystem once USB host mode is confirmed working.
CONFIG_USB=y
CONFIG_USB_ANNOUNCE_NEW_DEVICES=y
CONFIG_USB_MON=y
CONFIG_USB_STORAGE=y
# USB gadget / OTG support (for device mode)
CONFIG_USB_GADGET=y
CONFIG_USB_OTG=y

# ── Filesystems for USB storage ───────────────────────────────────────────
CONFIG_VFAT_FS=y
CONFIG_FAT_DEFAULT_CODEPAGE=437
CONFIG_FAT_DEFAULT_IOCHARSET="utf8"
CONFIG_EXT4_FS=y
CONFIG_EXT4_USE_FOR_EXT2=y

# ── MTD / flash ───────────────────────────────────────────────────────────
# Needed to mount the cramfs rootfs from SPI-NOR flash.
CONFIG_MTD=y
CONFIG_MTD_BLOCK=y
CONFIG_MTD_SPI_NOR=y
CONFIG_CRAMFS=y
CONFIG_JFFS2_FS=y
