# Buildroot minimal defconfig for BigTreeTech PandaTouch
#
# USE THIS CONFIG to get Linux booting as quickly as possible.
#
# Compared to esp32s3_pandatouch_defconfig this strips:
#   - Kernel extras (framebuffer, GT911 touch, USB host drivers)
#   - Device-tree source (framebuffer DT node not needed for serial boot)
#   - All packages except BusyBox (no wpa_supplicant, tslib, mtd-utils, etc.)
#
# You still get:
#   - A working serial console (UART0, ttyS0, 115200 baud)
#   - BusyBox init + sh
#   - Writable /etc (jffs2) for persistent config changes
#
# For the full-featured image (WiFi, framebuffer, touch, USB, tools)
# use esp32s3_pandatouch_defconfig instead.
#
# Build with:
#   ./esp32-linux-build/rebuild-esp32s3-pandatouch-minimal.sh

# ── Architecture ──────────────────────────────────────────────────────────
BR2_xtensa=y
BR2_XTENSA_DYNCONFIG=y
BR2_XTENSA_LITTLE_ENDIAN=y
BR2_XTENSA_USE_MMU=y
# Try to set BR2_USE_MMU=y. This may be silently dropped by olddefconfig in
# the jcmvbkbc fork (broken select chain). The definitive fix is three-part:
# 1. br2-external/external.mk overrides BUSYBOX_SET_MMU (disables CONFIG_NOMMU)
# 2. busybox-mmu.config adds CONFIG_EXTRA_CFLAGS="-D__ARCH_USE_MMU__" (forces BB_MMU=1)
# 3. Build scripts pass BR2_USE_MMU=y on the make command line
BR2_USE_MMU=y

# ── Toolchain ─────────────────────────────────────────────────────────────
BR2_TOOLCHAIN_EXTERNAL=y
BR2_TOOLCHAIN_EXTERNAL_CUSTOM=y
BR2_TOOLCHAIN_EXTERNAL_PATH=""
BR2_TOOLCHAIN_EXTERNAL_GCC_12=y
BR2_TOOLCHAIN_EXTERNAL_HEADERS_6_6=y
BR2_TOOLCHAIN_EXTERNAL_CUSTOM_UCLIBC=y
BR2_TOOLCHAIN_EXTERNAL_WCHAR=y
BR2_TOOLCHAIN_EXTERNAL_HAS_SSP=y
BR2_TOOLCHAIN_EXTERNAL_CXX=y

# ── Build options ─────────────────────────────────────────────────────────
BR2_OPTIMIZE_S=y

# ── Kernel – base esp32s3 defconfig only ──────────────────────────────────
# No framebuffer, no touch, no USB host extras.
# The base esp32s3_defconfig already enables serial UART, SPI-NOR, cramfs
# and jffs2 – everything needed to boot to a BusyBox shell.
BR2_LINUX_KERNEL=y
BR2_LINUX_KERNEL_CUSTOM_GIT=y
BR2_LINUX_KERNEL_CUSTOM_REPO_URL="https://github.com/jcmvbkbc/linux-xtensa.git"
BR2_LINUX_KERNEL_CUSTOM_REPO_VERSION="xtensa-fdpic"
BR2_LINUX_KERNEL_DEFCONFIG="esp32s3"
BR2_LINUX_KERNEL_IMAGE_TARGET_NAME="xipImage"

# ── System ────────────────────────────────────────────────────────────────
BR2_TARGET_GENERIC_HOSTNAME="pandatouch"
BR2_TARGET_GENERIC_ISSUE="BigTreeTech PandaTouch Linux (minimal)"
# Reuse the same rootfs overlay and post-scripts as the full build.
# /etc/inittab and /etc/cmdline (serial console) are provided by the overlay.
# The display/touch init scripts (S10display, S20touchscreen) are harmless
# on a minimal image – they exit gracefully when /dev/fb0 is absent.
BR2_ROOTFS_OVERLAY="$(BR2_EXTERNAL_PANDATOUCH_PATH)/board/pandatouch/rootfs-overlay"
BR2_ROOTFS_POST_BUILD_SCRIPT="$(BR2_EXTERNAL_PANDATOUCH_PATH)/board/pandatouch/post-build.sh"
BR2_ROOTFS_POST_FAKEROOT_SCRIPT="$(BR2_EXTERNAL_PANDATOUCH_PATH)/board/pandatouch/mkfs-etc.sh"
BR2_ROOTFS_POST_IMAGE_SCRIPT="$(BR2_EXTERNAL_PANDATOUCH_PATH)/board/pandatouch/post-image.sh"

# ── Root filesystem ───────────────────────────────────────────────────────
BR2_TARGET_ROOTFS_CRAMFS=y
BR2_TARGET_ROOTFS_JFFS2=y
BR2_TARGET_ROOTFS_JFFS2_FLASH_64=y

# ── Packages – BusyBox only ───────────────────────────────────────────────
BR2_PACKAGE_BUSYBOX=y
# Force CONFIG_MMU=y so ash compiles (ESP32-S3 has a hardware MMU).
BR2_PACKAGE_BUSYBOX_CONFIG_FRAGMENT_FILES="$(BR2_EXTERNAL_PANDATOUCH_PATH)/board/pandatouch/busybox-mmu.config"
